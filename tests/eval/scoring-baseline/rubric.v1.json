{
  "contractVersion": "scoring-baseline/v1",
  "dataset": {
    "caseCount": 100,
    "casesPerTool": 20,
    "sourceTools": [
      "codex",
      "claude-code",
      "opencode",
      "workbuddy",
      "qoder"
    ],
    "source": "synthetic"
  },
  "availabilityStates": [
    "present",
    "observed_absent",
    "unavailable"
  ],
  "recordContract": {
    "goldRequiredFields": [
      "caseId",
      "sourceTool",
      "evidenceWindow",
      "taskBoundary",
      "project",
      "acceptedTaskNames",
      "deliverable",
      "verificationStatus",
      "complexity",
      "dimensionScores",
      "evidenceGates",
      "riskLabels",
      "confidence",
      "availability"
    ],
    "predictionRequiredFields": [
      "caseId",
      "taskBoundary",
      "project",
      "taskName",
      "deliverable",
      "verificationStatus",
      "complexity",
      "dimensionScores",
      "evidenceGates",
      "riskLabels",
      "confidence"
    ],
    "deliverableMeaning": "task_output_not_necessarily_reusable",
    "reusableAssetRequires": "asset_evidence_gate_present"
  },
  "dimensions": {
    "taskDefinition": 20,
    "collaborationOrchestration": 20,
    "iterationDepth": 20,
    "verificationClosure": 25,
    "assetCreation": 15
  },
  "complexityWeights": [
    1,
    2,
    3
  ],
  "aggregation": {
    "taskUnavailableDimensionResult": null,
    "taskScore": "weighted_sum_when_all_dimensions_available",
    "dayScore": "complexity_weighted_mean_of_valid_tasks",
    "dayWithoutValidTasksResult": null,
    "rolling28DayScore": "equal_mean_of_valid_active_day_scores",
    "minimumActiveDaysForMaturity": 3
  },
  "maturity": {
    "assignment": {
      "scoreBandCandidate": "highest_level_whose_scoreFloor_is_met",
      "evaluationDirection": "from_candidate_downward",
      "fallbackIgnoresScoreBandCeiling": true,
      "result": "first_level_whose_evidence_gate_passes"
    },
    "insufficientActiveDaysResult": null,
    "L1": {
      "scoreFloor": 0,
      "scoreBandCeiling": 39,
      "evidenceGate": "none"
    },
    "L2": {
      "scoreFloor": 40,
      "scoreBandCeiling": 59,
      "evidenceGate": "none"
    },
    "L3": {
      "scoreFloor": 60,
      "scoreBandCeiling": 79,
      "minimumIteratedAndVerifiedTasks": 3
    },
    "L4": {
      "scoreFloor": 80,
      "scoreBandCeiling": 100,
      "minimumIteratedAndVerifiedTasks": 5,
      "minimumReusableAssetTasks": 2
    }
  },
  "qualityGates": {
    "jointTaskNameProjectConsistency": {
      "taskNameMatch": "prediction_taskName_in_gold_acceptedTaskNames",
      "projectMatch": "exact",
      "overallMinimum": 0.8,
      "perToolMinimum": 0.7
    },
    "boundaryF1": {
      "report": true,
      "includedInJointConsistency": false
    },
    "aggregationExactMatch": true,
    "maturityExactMatch": true,
    "usageOnlyRiskNegativeGate": true
  },
  "prohibitedScoringInputs": [
    "tokenCount",
    "duration",
    "sessionCount",
    "toolCallCount",
    "skillCount",
    "subagentCount"
  ],
  "policy": {
    "workbuddy": "unsupported/policy_restriction",
    "qoder": "unsupported/policy_restriction",
    "syntheticEvidenceDoesNotChangeAdapterStatus": true
  }
}
